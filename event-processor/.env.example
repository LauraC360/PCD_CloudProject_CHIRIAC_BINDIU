# DynamoDB table for movie view count statistics (MovieStats)
DYNAMODB_TABLE_STATS=MovieStats

# DynamoDB table for idempotency tracking (ProcessedEvents)
DYNAMODB_TABLE_EVENTS=ProcessedEvents

# DynamoDB table for recent activity feed (RecentActivity)
DYNAMODB_TABLE_RECENT_ACTIVITY=RecentActivity

# Internal URL of the WebSocket Gateway (Lambda → Gateway via Cloud Map DNS)
GATEWAY_INTERNAL_URL=http://wsg.local:8081

# AWS region
AWS_REGION=us-east-1

# SQS batch size (configured on the event source mapping in CDK)
SQS_BATCH_SIZE=10
