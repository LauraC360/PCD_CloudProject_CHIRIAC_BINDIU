# Runtime environment
NODE_ENV=development

# Server port
APP_PORT=3000

# MongoDB connection string (injected from SSM in production)
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# MongoDB database name (sample_mflix for the Atlas sample dataset)
MONGO_DB_NAME=sample_mflix

# SQS queue URL for publishing view events (from CDK output: AnalyticsViewEventsQueueUrl)
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account-id>/view-events

# AWS region
AWS_REGION=us-east-1

# Cognito JWKS endpoint for JWT validation (from CDK output: AnalyticsCognitoJwksUrl)
COGNITO_JWKS_URL=https://cognito-idp.us-east-1.amazonaws.com/<user-pool-id>/.well-known/jwks.json

# CloudWatch metrics flush interval in ms (how often to batch-publish metrics)
CLOUDWATCH_METRICS_FLUSH_INTERVAL_MS=30000
